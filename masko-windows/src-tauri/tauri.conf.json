{
  "$schema": "https://raw.githubusercontent.com/nicedoc/ts-json-schema-generator/refs/heads/master/tauri-v2-schema.json",
  "productName": "Masko",
  "version": "1.7.0",
  "identifier": "ai.masko.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Masko Code",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCRUM5Q0VDRDM5RDhCRDMKUldUVGk1M1Q3SnpzdTdLaUZwZHgvMkkvRHl0QjYzTDhnS2loUkpWcEtHRlRsM3g5cnRjdTZXTUcK",
      "endpoints": [
        "https://github.com/paquoc/masko-code/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
